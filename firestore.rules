rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['rafael@rclr.com.br', 'larissa@rclr.com.br'];
    }
    match /posts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /talks/{id} { allow read: if true; allow write: if isAdmin(); }
    match /topics/{id} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}